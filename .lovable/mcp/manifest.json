{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ogfrdzezfftelwuokogj.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "screen-share-studio-mcp",
      "version": "0.1.0",
      "title": "Screen Share Studio"
    },
    "tools": [
      {
        "name": "list_layouts",
        "title": "List layouts",
        "description": "List the signed-in user's saved custom layouts, newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "folder": {
              "description": "Optional folder name to filter by.",
              "type": "string"
            },
            "limit": {
              "description": "Max rows to return (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_layout",
        "title": "Get layout",
        "description": "Fetch one custom layout by id, including its full spec JSON.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Layout id."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "create_layout",
        "title": "Create layout",
        "description": "Create a new custom layout owned by the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200,
              "description": "Layout display name."
            },
            "spec": {
              "description": "Layout spec JSON (blocks, positions, etc.)."
            },
            "folder": {
              "description": "Optional folder name.",
              "type": "string"
            }
          },
          "required": [
            "name",
            "spec"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "delete_layout",
        "title": "Delete layout",
        "description": "Delete a custom layout owned by the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Layout id to delete."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_chat_messages",
        "title": "List chat messages",
        "description": "List recent chat messages from a room, newest last.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "room_id": {
              "description": "Room id (default 'main').",
              "type": "string"
            },
            "limit": {
              "description": "Max rows (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "send_chat_message",
        "title": "Send chat message",
        "description": "Post a message to the studio chat as the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "body": {
              "type": "string",
              "minLength": 1,
              "maxLength": 2000,
              "description": "Message text."
            },
            "display_name": {
              "description": "Optional display name override.",
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "room_id": {
              "description": "Room id (default 'main').",
              "type": "string"
            }
          },
          "required": [
            "body"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
